# Copy this file to .env and provide your DeepSeek API key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# SentenceTransformer reuses the Hugging Face cache automatically.
BGE_MODEL=BAAI/bge-small-en-v1.5
# BGE_MODEL_PATH=C:/path/to/an/existing/local/bge-model

ATTRIBUTE_SIMILARITY_THRESHOLD=0.85
